[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mIf the package regex.cls is available, then the names starting with \"/\" are\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mregular expressions which are compiled into a pattern.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mOtherwise the names are just string patterns. The character \"*\" has a special\r\n"]
