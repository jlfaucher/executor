[0.002, "o", "\u001b[1;32m\r\n\u001b[0m\u001b[1;32mREXX-ooRexx_4.3.0(MT)_64-bit 6.04 12 May 2026\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;32mInput queue name: S16dc6Q600001980c30\r\n\u001b[0m"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m--------------\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- ooRexxShell\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m--------------\r\n\u001b[0m"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mTo have an overview of the supported queries, enter a question mark:\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m?\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
[0.000, "o", "ooRexx[bash]> "]
[2.379, "o", "\u001b[1;35m?"]
[0.053, "o", "\u001b[0m"]
[2.011, "o", "\r\n"]
[0.002, "o", "Queries:\r\n"]
[0.000, "o", "    ?: display help.\r\n    ?bt: display the backtrace of the last error (same as ?tb).\r\n"]
[0.001, "o", "    ?c[lasses] c1 c2... : display classes.\r\n    ?c[lasses].m[ethods] c1 c2... : display local methods per classes (cm).\r\n"]
[0.000, "o", "    ?c[lasses].m[ethods].i[nherited] c1 c2... : local & inherited methods (cmi).\r\n"]
[0.000, "o", "    ?d[ocumentation]: invoke ooRexx documentation.\r\n"]
[0.000, "o", "    ?f[lags]: describe the flags displayed for classes & methods & routines.\r\n"]
[0.000, "o", "    ?h[elp] c1 c2 ... : local description of classes.\r\n"]
[0.000, "o", "    ?h[elp].i[nherited] c1 c2 ... : local & inherited description of classes (hi).\r\n"]
[0.000, "o", "    ?i[nterpreters]: interpreters that can be selected.\r\n"]
[0.000, "o", "    ?meta[data]: describe the metadata displayed in verbose mode.\r\n"]
[0.000, "o", "    ?m[ethods] m1 m2 ... : display methods.\r\n"]
[0.000, "o", "    ?p[ackages] p1 p2 ... : display the loaded packages.\r\n"]
[0.000, "o", "    ?path v1 v2 ... : display value of system variable, splitted by path separator.\r\n"]
[0.000, "o", "    ?r[outines] r1 r2... : display routines.\r\n"]
[0.000, "o", "    ?s[ettings]: display ooRexxShell settings.\r\n"]
[0.000, "o", "    ?sf: display the stack frames of the last error.\r\n"]
[0.000, "o", "    ?tb: display the traceback of the last error (same as ?bt).\r\n    ?v[ariables]: display the defined variables.\r\n"]
[0.001, "o", "    Option .s[ource] applicable to ?m, ?p and ?r queries:\r\n        Display the source of methods, packages or routines.\r\n"]
[0.000, "o", "        Short: ?cms, ?cmis, ?ms, ?ps, ?rs.\r\n"]
[0.000, "o", "    Option .v[erbose] applicable to ?c, ?m, ?p and ?r queries:\r\n"]
[0.000, "o", "        Display the metadata of classes, methods or routines.\r\n"]
[0.000, "o", "        Short: ?cv, ?cmv, ?cmiv, ?cmsv, ?cmisv, ?mv, ?msv, ?pv, ?psv, ?rv, ?rsv.\r\n"]
[0.000, "o", "    Option package width applicable to ?c, ?m, ?p and ?r queries:\r\n"]
[0.000, "o", "        Example: ?cm -3 RexxContext RexxInfo\r\n"]
[0.000, "o", "        n > 0 display the package full path truncated to n characters from the end.\r\n"]
[0.000, "o", "        n = 0 display the package filename without truncation.\r\n"]
[0.000, "o", "        n < 0 display the package full path truncated to abs(n) directories from the end.\r\n"]
[0.000, "o", "Commands:\r\n"]
[0.000, "o", "    /* alone: Used in a demo to start a multiline comment. Ended by */ alone.\r\n"]
[0.000, "o", "    < filename: read the file and put each line in the queue.\r\n"]
[0.000, "o", "    color off|on: deactivate|activate the colors.\r\n"]
[0.001, "o", "    color codes off|on: deactivate|activate the display of the color codes.\r\n"]
[0.000, "o", "    debug off|on: deactivate|activate the full trace of the internals of ooRexxShell.\r\n"]
[0.000, "o", "    demo off|on|fast: deactivate|activate the demonstration mode.\r\n"]
[0.000, "o", "    exit: exit ooRexxShell.\r\n"]
[0.000, "o", "    goto <label>: used in a demo script to skip lines, until <label:> (note colon) is reached.\r\n"]
[0.000, "o", "    indent+ | indent-: used by the command < to show the level of inclusion.\r\n    infos off|on|next: deactivate|activate the display of information after each execution."]
[0.000, "o", "\r\n    prompt off|on [a[ddress]] [d[irectoy]] [i[nterpret]]: deactivate|activate the display of the prompt components.\r\n"]
[0.000, "o", "    readline off: use the raw parse pull for the input.\r\n"]
[0.000, "o", "    readline on: delegate to the system readline (history, tab completion).\r\n"]
[0.000, "o", "    reload: exit the current session and reload all the packages/libraries.\r\n"]
[0.000, "o", "    security off: deactivate the security manager. No transformation of commands.\r\n"]
[0.000, "o", "    security on : activate the security manager. Transformation of commands.\r\n"]
[0.000, "o", "    sleep [n] [no prompt]: used in demo mode to pause during n seconds (default 2 sec).\r\n"]
[0.000, "o", "    test regression: activate the regression testing mode.\r\n"]
[0.000, "o", "    trace off|on [d[ispatch]] [f[ilter]] [r[eadline]] [s[ecurity][.verbose]]: deactivate|activate the trace.\r\n"]
[0.001, "o", "    trap off|on [l[ostdigits]] [nom[ethod]] [nos[tring]] [nov[alue]] [s[yntax]]: deactivate|activate the conditions traps.\r\nInput queue name: S16dc6Q600001980c30"]
[0.000, "o", "\r\n"]
