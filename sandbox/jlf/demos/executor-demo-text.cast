[0.055, "o", "\u001b[1;34m-- the Byte_Encoding is not the privileged resulting encoding"]
[0.000, "o", "\u001b[0m\u001b[0m"]
[2.002, "o", "\r\n"]
[0.002, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m----------------\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- Text encoding\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m----------------\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mStart working on a prototype for encoded strings.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mMain ideas explored with this prototype :\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m- The existing String class is kept unchanged, but its semantic becomes : \"byte-oriented\".\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m- The prototype adds a layer of services working at grapheme level, provided by the RexxText class.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m- The RexxText class works on the bytes managed by the String class.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m- String instances are immutable, the same for RexxText instances.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m- No automatic conversion to Unicode by the interpreter.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m- The strings crossing the I/O barriers are kept unchanged.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m- Supported encodings : byte, UTF-8, UTF-16, UTF-32.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[15.008, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m/*\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mOn my Mac, where locale returns :\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mLANG=\"\"\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mLC_COLLATE=\"en_US.UTF-8\"\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mLC_CTYPE=\"en_US.UTF-8\"\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mLC_MESSAGES=\"en_US.UTF-8\"\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mLC_MONETARY=\"en_US.UTF-8\"\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mLC_NUMERIC=\"en_US.UTF-8\"\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mLC_TIME=\"en_US.UTF-8\"\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mLC_ALL=\"en_US.UTF-8\"\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mI get that under ooRexxShell :\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
