[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mA String is linked to a RexxText, which itself is linked to this String:\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m    a String\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m     ▲  text --------> a RexxText\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m     │                     indexer (anEncoding)\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m     │                          codepoints (sequential access)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m     │                          characters (direct access to graphemes)"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m     +-<---------------------<- string\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe ooRexx programmer has the choice :\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m- working with String at byte level\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m- working with RexxText at grapheme level.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m- the same instance of String is used in both cases."]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
