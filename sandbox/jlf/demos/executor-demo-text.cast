[0.000, "o", "/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mStrings of codepoints encoded as native integers.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m3 representations:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    Unicode8_Encoding\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    Unicode16_Encoding\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    Unicode32_Encoding.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe method ~unicode returns one of these encodings, depending on the character\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mwith the largest Unicode codepoint (1, 2, or 4 bytes) in the source string.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mUnlike the flexible representation of Python, the 3 representions are first-class.\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mNo BOM, the endiannes is the CPU one.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mUnicode32_Encoding can be used with utf8proc for the functions taking a buffer of 32-bit integers.\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
