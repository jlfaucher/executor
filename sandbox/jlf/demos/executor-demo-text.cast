[0.008, "o", "(The UTF16BE_Encoding class)\r\n"]
[0.000, "o", "ooRexx[bash]> "]
[2.005, "o", "\u001b[1;35ms"]
[0.000, "o", "~"]
[0.052, "o", "h"]
[0.055, "o", "a"]
[0.053, "o", "s"]
[0.053, "o", "T"]
[0.052, "o", "e"]
[0.056, "o", "x"]
[0.052, "o", "t"]
[0.054, "o", " "]
[0.052, "o", "= "]
[0.054, "o", "        "]
[0.000, "o", "  "]
[0.000, "o", "   "]
[0.000, "o", "       "]
[0.001, "o", "\u001b[1;34m-- still no associated RexxText: 0"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[0m"]
[2.005, "o", "\r\n"]
[0.001, "o", " 0\r\n"]
[0.001, "o", "ooRexx[bash]> "]
[2.007, "o", "\u001b[1;35mt "]
[0.055, "o", "= "]
[0.054, "o", "s~"]
[0.052, "o", "t"]
[0.051, "o", "e"]
[0.055, "o", "x"]
[0.055, "o", "t"]
[0.051, "o", " "]
[0.058, "o", "                     \u001b[1;34m-- associates a RexxText to the string\u001b[0m\u001b[0m"]
[2.005, "o", "\r\n"]
[0.003, "o", "ooRexx[bash]> "]
[0.001, "o", "\u001b[1;35ms~"]
[0.054, "o", "h"]
[0.051, "o", "a"]
[0.057, "o", "s"]
[0.053, "o", "T"]
[0.055, "o", "e"]
[0.056, "o", "x"]
[0.051, "o", "t"]
[0.054, "o", " "]
[0.051, "o", "= "]
[0.055, "o", "      "]
[0.000, "o", "  "]
[0.000, "o", "            "]
[0.000, "o", "\u001b[1;34m-- the string has an associated text: 1"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[0m"]
[2.005, "o", "\r\n"]
[0.003, "o", " 1\r\n"]
[0.000, "o", "ooRexx[bash]> "]
[2.001, "o", "\u001b[1;35mt~"]
[0.054, "o", "e"]
[0.054, "o", "n"]
[0.052, "o", "c"]
[0.054, "o", "o"]
[0.055, "o", "d"]
[0.054, "o", "i"]
[0.055, "o", "n"]
[0.051, "o", "g"]
[0.056, "o", " "]
[0.055, "o", "= "]
[0.055, "o", "     "]
[0.000, "o", " "]
[0.000, "o", " "]
[0.001, "o", "            "]
[0.000, "o", "\u001b[1;34m-- the encoding of the text is the one of the string: (The UTF16BE_Encoding class)"]
[0.000, "o", "\u001b[0m\u001b[0m"]
[2.001, "o", "\r\n"]
[0.002, "o", "(The UTF16BE_Encoding class)\r\n"]
[2.007, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m-- Changing the encoding of a String/RexxText has no impact on the byte sequence.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "ooRexx[bash]> "]
[0.001, "o", "\u001b[1;35ms="]
[0.055, "o", " "]
[0.057, "o", "                 "]
[0.001, "o", "         "]
[0.000, "o", "   "]
[0.000, "o", "\u001b[1;34m-- \"nonsense\"\u001b[0m\u001b[0m"]
[2.025, "o", "\r\n'nonsense'\r\n"]
[0.001, "o", "ooRexx[bash]> "]
[2.006, "o", "\u001b[1;35mt~"]
[0.052, "o", "s"]
[0.057, "o", "t"]
[0.051, "o", "r"]
[0.052, "o", "i"]
[0.054, "o", "n"]
[0.052, "o", "g"]
[0.052, "o", "="]
[0.052, "o", " "]
[0.054, "o", "     "]
[0.000, "o", "   "]
[0.000, "o", "             "]
[0.000, "o", " "]
[0.001, "o", "\u001b[1;34m-- \"nonsense\""]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[0m"]
[2.005, "o", "\r\n"]
[0.001, "o", "'nonsense'\r\n"]
[2.008, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m-- The impact of the encoding annotation is on the decoding of the byte sequence.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- The english word \"nonsense\" in UTF-8 becomes the chinese word \"soup\" when interpreted as UTF-16BE and converted to UTF-8.\r\n\u001b[0m"]
[0.001, "o", "ooRexx[bash]> "]
[2.004, "o", "\u001b[1;35mt~"]
[0.056, "o", "u"]
[0.055, "o", "t"]
[0.052, "o", "f"]
[0.055, "o", "8"]
[0.055, "o", " "]
[0.055, "o", "= "]
[0.051, "o", "         "]
[0.000, "o", "           "]
[0.001, "o", "   "]
[0.000, "o", "\u001b[1;34m-- T'湯湳敮獥'      soup\u001b[0m\u001b[0m"]
[2.002, "o", "\r\n"]
[0.004, "o", "T'湯湳敮獥'\r\n"]
[2.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "-- Setting/getting the encoding of the string will set/get the encoding of the associated RexxText\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "ooRexx[bash]> "]
[2.003, "o", "\u001b[1;35ms~"]
[0.054, "o", "e"]
[0.056, "o", "n"]
[0.053, "o", "c"]
[0.054, "o", "o"]
[0.053, "o", "d"]
[0.055, "o", "i"]
[0.053, "o", "n"]
[0.052, "o", "g"]
[0.055, "o", " "]
[0.059, "o", "= "]
[0.051, "o", ".U"]
[0.051, "o", "T"]
[0.053, "o", "F"]
[0.056, "o", "1"]
[0.054, "o", "6"]
[0.055, "o", "L"]
[0.055, "o", "E"]
[0.052, "o", "_"]
[0.052, "o", "E"]
[0.052, "o", "n"]
[0.056, "o", "c"]
[0.055, "o", "o"]
[0.055, "o", "d"]
[0.054, "o", "i"]
[0.052, "o", "n"]
[0.052, "o", "g"]
[0.104, "o", "\u001b[0m"]
[2.003, "o", "\r\n"]
[0.003, "o", "ooRexx[bash]> "]
[0.000, "o", "\u001b[1;35mt~"]
[0.053, "o", "e"]
[0.055, "o", "n"]
[0.054, "o", "c"]
[0.055, "o", "o"]
[0.054, "o", "d"]
[0.056, "o", "i"]
[0.052, "o", "n"]
[0.052, "o", "g"]
[0.056, "o", " "]
[0.053, "o", "= "]
[0.050, "o", "       "]
[0.000, "o", "  "]
[0.000, "o", " "]
[0.001, "o", "         "]
[0.000, "o", "\u001b[1;34m-- the encoding of the text has been changed: (The UTF16LE_Encoding class)\u001b[0m"]
[0.000, "o", "\u001b[0m"]
[2.001, "o", "\r\n"]
[0.002, "o", "(The UTF16LE_Encoding class)\r\n"]
[0.000, "o", "ooRexx[bash]> "]
[2.004, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m-- The english word \"nonsense\" in UTF-8 becomes the chinese word \"tide\" when interpreted as UTF-16LE and converted to UTF-8.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "ooRexx[bash]> "]
[2.004, "o", "\u001b[1;35mt~"]
[0.053, "o", "u"]
[0.053, "o", "t"]
[0.055, "o", "f"]
[0.053, "o", "8"]
[0.052, "o", " "]
[0.054, "o", "= "]
[0.053, "o", "         "]
[0.000, "o", "      "]
[0.000, "o", " "]
[0.000, "o", "       "]
[0.001, "o", "\u001b[1;34m-- T'潮獮湥敳'      tide\u001b[0m"]
[0.000, "o", "\u001b[0m"]
[2.005, "o", "\r\n"]
[0.003, "o", "T'潮獮湥敳'\r\n"]
[2.007, "o", "\r\n"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
