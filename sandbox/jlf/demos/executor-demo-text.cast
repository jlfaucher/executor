[0.002, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mU+FE0E VARIATION SELECTOR-15 (UTF-8: EF B8 8E)\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mhttps://codepoints.net/U+fe0e\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mThis codepoint may change the appearance of the preceding character.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mIf that is a symbol, dingbat or emoji, U+FE0E forces it to be rendered in a\r\n\u001b[0m"]
[0.002, "o", "\u001b[1;34mtextual fashion as compared to a colorful image.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mU+FE0F VARIATION SELECTOR-16 (UTF-8: EF B8 8F)\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mhttps://codepoints.net/U+fe0f\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThis codepoint may change the appearance of the preceding character.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mIf that is a symbol, dingbat or emoji, U+FE0F forces it to be rendered as a\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mcolorful image as compared to a monochrome text variant.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mIn theory ❤ and ❄ (and many other emoji) should display as text style by default\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mwithout VS16, but many applications ignore that.\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
