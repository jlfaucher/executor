[0.000, "o", "/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mComparing the size of UTF-8 vs UTF-16 vs UTF-32 for various strings.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThese strings are initially UTF-8 encoded.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe first step is to get a wrapper RexxText (default encoding is UTF-8).\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "The second step is to convert to UTF-16 or UTF-32.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe description includes technical informations (technical:1) about the internal tables for indexation.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
[0.000, "o", "ooRexx[bash]> "]
