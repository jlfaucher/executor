[0.000, "o", "\u001b[1;34m-- For this maximum codepoint, we need Unicode32\u001b[0m\u001b[0m"]
[2.002, "o", "\r\n"]
[0.005, "o", "'Unicode32 (5 characters (1 index from index 5), 10 codepoints (0 index), 40 bytes, 0 error)'\r\n"]
[2.007, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m-- The endianness of the UnicodeN_Encoding is the one of the machine.\r\n"]
