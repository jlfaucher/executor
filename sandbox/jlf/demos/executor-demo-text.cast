[0.000, "o", "\u001b[1;32mREXX-ooRexx_4.3.0(MT)_64-bit 6.04 1 Mar 2026\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;32mInput queue name: Sb183Q6000019d5860\r\n\u001b[0m"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m-- These demos were designed before the introduction of the immediate\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- \"invalid text\" error and before the introduction of the privileged encoding\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- status of Byte_Encoding.\r\n\u001b[0m"]
[0.000, "o", "ooRexx[bash]> \u001b[1;35m.U"]
