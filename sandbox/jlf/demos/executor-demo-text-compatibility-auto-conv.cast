[0.001, "o", "\u001b[1;34m-- caselessPos in not-aligned mode\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34maligned=.false is intended for analysis of matchings and [non-]regression tests.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mOtherwise, I don't see any use.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mIf aligned=.false then return a couple (array) of numbers +/-posC.posB where\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mposB is the position of the matched byte in the transformed haystack, and posC\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mis the corresponding grapheme position in the untransformed haystack.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mA number is negative if the byte position is not aligned with the corresponding\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mcharacter position.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe first number is the start of the matching.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe second number is the end of the matching + 1.\r\n"]
[0.000, "o", "\u001b[0m"]
