[0.000, "o", "\u001b[1;34m----------------------------------------------------------------\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- Text encoding - Compatibility with String\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- Automatic conversion of String literals to RexxText instances"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m----------------------------------------------------------------\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mCompatibility with the class String.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThis is a work in progress, many methods not yet supported,\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mUnicode implementation still missing for many methods.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[5.046, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mThis string is used in several places:\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\"noël👩‍👨‍👩‍👧🎅\"\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "Depending on your editor/browser, you may see 5 emojis, or 3 emojis.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mWith Unicode 13, the display is 3 emojis (woman + family + father christmas).\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m👩\tU+1F469\tWOMAN\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m‍\tU+200D\tZERO WIDTH JOINER\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m👨\tU+1F468\tMAN\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m‍\tU+200D\tZERO WIDTH JOINER\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m👩\tU+1F469\tWOMAN\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m‍\tU+200D\tZERO WIDTH JOINER\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m👧\tU+1F467\tGIRL\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m🎅\tU+1F385\tFATHER CHRISTMAS\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mNotice that 👩‍👨‍👩‍👧 constitute only 1 grapheme thanks to the ZERO WIDTH JOINER.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
