[0.000, "o", "/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mA caseless method is transforming its arguments using CaseFold.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe default normalization is NFC, it's possible to change it with the argument\r\n"]
