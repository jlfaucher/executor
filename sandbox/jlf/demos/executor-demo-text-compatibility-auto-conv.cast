[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThere is no value NFKC_CF because it can be done using the caseless methods by\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mpassing NFKC + stripIgnorable.\r\n"]
[0.000, "o", "\u001b[0m"]
