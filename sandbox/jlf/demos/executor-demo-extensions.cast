[2.007, "o", "\r\n"]
[0.002, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mBlocks\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mA RexxBlock is a piece of source code surrounded by curly brackets."]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m{say \"Hello\"}\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mOptional tags after \"{\":\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m::routine       (abbreviation ::r, this is the default tag)\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m::coactivity    (abbreviation ::co)\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mBig picture :\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mA RexxSourceLiteral is an internal rexx object, created by the parser, not accessible from ooRexx scripts.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mA RexxSourceLiteral holds the following properties, shared among all the RexxBlock instances created from it :\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m- source: the text between the curly brackets {...} as an array of lines, including the tag ::xxx if any.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m- package: the package which contain the source literal.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m- kind: kind of source, derived from the source's tag.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m- rawExecutable: routine or method created at load-time (immediate parsing).\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m- executable: cached executable.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mA RexxBlock is created each time the RexxSourceLiteral is evaluated, and is accessible from ooRexx scripts.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mWhen a RexxBlock is a closure's source, it will hold a snapshot of the context's variables.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
