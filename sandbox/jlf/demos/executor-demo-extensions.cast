[2.006, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mCoactivity\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mEmulation of coroutine, named \"coactivity\" to follow the ooRexx vocabulary.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThis is not a \"real\" coroutine implementation, because it's based on ooRexx\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mthreads and synchronization. But at least you have all the functionalities of a\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mstackful asymmetric coroutine (resume + yield).\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mA stackful coroutine is a coroutine able to suspend its execution from within\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mnested calls. The variable .threadLocal is used to retrieve the coactivity\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34minstance from any invocation and send it the message yield (this instance is at\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mthe origin of the invocations stack, but is not passed as a parameter to the\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34minvocations).\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mmyCoactivity~start  <--------------+"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    invocation                     |"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m        invocation                 |\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m            ...                    |\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m                invocation: .Coactivity~yield()\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mA coactivity remembers its internal state. It can be called several times, the\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mexecution is resumed after the last executed \".yield[]\" or \"call yield\".\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "ooRexx[bash]> "]
