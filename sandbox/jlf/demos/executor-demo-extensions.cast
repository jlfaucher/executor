[2.001, "o", "\r\n"]
[0.154, "o", "PM P...    'YM' : 'RoutineDoer' (doers.cls)\r\n > 0001 use named arg verbose=.false\r\n"]
[0.000, "o", " > 0002     if verbose then trace i\r\n"]
[0.000, "o", " > 0003 \r\n > 0004     -- lambda_f\r\n"]
[0.000, "o", " > 0005     f = self -- to be closer to the notation (would be passed by parameter to lambda_f when implemented by a function instead of a method)\r\n > 0006     YnamedArgs = .context~namedArgs\r\n > 0007     table = .Table~new\r\n > 0008 \r\n > 0009     lambda_x = {\r\n > 0010         expose f verbose YnamedArgs table\r\n"]
[0.001, "o", " > 0011         if verbose then trace i\r\n > 0012         use strict arg x\r\n > 0013         lambda_v = {\r\n > 0014                      expose x verbose table\r\n"]
[0.000, "o", " > 0015                      if verbose then trace i\r\n"]
[0.000, "o", " > 0016                      --use strict arg v\r\n > 0017                      v = arg(1, \"a\")\r\n > 0018                      v_index = v~tostring\r\n"]
[0.000, "o", " > 0019                      r = table[v_index]\r\n"]
[0.000, "o", " > 0020                      if .nil <> r then return r\r\n"]
[0.000, "o", " > 0021                      r = x~(x)~doWith(v, namedArguments: .context~namedArgs)\r\n > 0022                      table[v_index] = r\r\n"]
[0.000, "o", " > 0023                      return r\r\n"]
[0.000, "o", " > 0024                 }\r\n > 0025         return f ~ doWith(.array~of(lambda_v), namedArguments: YnamedArgs)\r\n"]
[0.000, "o", " > 0026     }\r\n"]
[0.000, "o", " > 0027     return lambda_x ~ (lambda_x)\r\n"]
