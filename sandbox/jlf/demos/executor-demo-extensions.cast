[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mNamed arguments\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThey have been added because they allow to get rid of the transformation of the\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mblock's sources at run-time (to declare positional arguments like item, index).\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mMore precisely, this instruction:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    use auto named args\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mlets the caller inject named variables in the scope of the callee.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
