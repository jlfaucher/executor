[0.000, "o", "\u001b[1;34msee RexxActivation::novalueHandler).\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe class GlobalVariables is used to manage global variables like i, infinity, indeterminate."]
