[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mY combinator:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe Y combinator allows recursion to be defined as a set of rewrite rules.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mIt takes a single argument, which is a function that isn't recursive (here, no argument, use self which is a Doer).\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mIt returns a version of the function which is recursive.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[8.670, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mInspired by http://mvanier.livejournal.com/2897.html\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mY = λf.(λx.f (λv.((x x) v))) (λx.f (λv.((x x) v)))\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m(define Y\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m  (lambda (f)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    ( (lambda (a) (a a))\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m      (lambda (x) (f (lambda (v) ((x x) v)))))))\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[6.769, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mImplementation of the Y combinator with memoization:\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
