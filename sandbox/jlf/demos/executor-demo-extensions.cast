[0.000, "o", "PM P...    'DO'      : 'StringDoer' (doers.cls)\r\nPM P...    'DO'      : 'TextDoer' (doers.cls)\r\n.. P.G.    'MESSAGE' : 'MESSAGEPROFILEDATA' (profiling.cls)\r\n"]
[0.000, "o", "\u001b[1;32m[Info] 9 lines displayed\r\n"]
