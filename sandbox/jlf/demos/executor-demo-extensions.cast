[10.024, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mSymmetric implementation of operator\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mOfficial ooRexx doesn't allow to define symmetric overriding of operators.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mYou can define a user operator on .array which supports .array~of(1,2) + 10.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mBut you can't define a user operator which supports 10 + .array~of(1,2).\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mExecutor has been extended to automatically try b~\"op:right\"(a) when a~\"op\"(b)\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mis about to raise an exception.\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mIf an alternate implementation exists then call it otherwise raise the exception.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe two methods Object::messageSend have been modified to let pass an additional\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mparameter 'processUnknown' which is true by default (legacy behavior). When this\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mparameter is false, and no method is found for the message, then\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mObject::messageSend returns false to indicate that no implementation exists.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThere is no processing of the unknown message.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThis is an efficient way to test if an alternate implementation exists and call it.\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mWhen the alternate implementation returns nothing, then don't complain about that.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mBehave as if the alternate implementation did not exist, and raise the exception\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mrelated to the left argument.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "*/\r\n"]
