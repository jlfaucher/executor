[0.000, "o", "\u001b[1;34mTilde-call message \"~()\".\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe message name can be omitted, but the list of parameters is mandatory (can be empty).\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    target~()\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    target~(arg1, arg2, ...)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    target~~()\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    target~~(arg1, arg2, ...)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mWhen the expression is evaluated, the target receives the message \"~()\" which\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mforwards the message \"do\".\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "ooRexx[bash]> "]
