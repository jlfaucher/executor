[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mTrailing block argument (similar to Groovy & Swift syntax for closures) :\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    f{...} is equivalent to f({...})\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m    f(a1,a2,...){...} is equivalent to f(a1,a2,...,{...})\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
