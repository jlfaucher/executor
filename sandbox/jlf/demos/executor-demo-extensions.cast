[2.003, "o", "\r\n"]
[0.156, "o", "P. P.G.    'CLASSES' : 'Package' (REXX)\r\nPM P.G.    'DO'      : 'Doer' (doers.cls)\r\nPM P...    'DO'      : 'CoactivityDoer' (doers.cls)"]
[0.000, "o", "\r\nPM P...    'DO'      : 'MethodDoer' (doers.cls)\r\n"]
[0.000, "o", "PM P...    'DO'      : 'RexxBlockDoer' (doers.cls)\r\n"]
