[0.002, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "Concurrency trace\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe interpreter has been modified to add thread id, activation id, variable's dictionnary id,\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "lock counter and lock flag in the lines printed by trace.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "Concurrency trace is displayed only when env variable RXTRACE_CONCURRENCY=ON\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "Informations that are displayed.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "RexxActivity::traceOutput(RexxActivation *activation, ..."]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mT1       SysCurrentThreadId(),\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mA2       (unsigned int)activation,\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "V1       (activation) ? activation->getVariableDictionary() : NULL      // settings.object_variables\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "1        (activation) ? activation->getReserveCount() : 0               // settings.object_variables->getReserveCount()\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "*        (activation && activation->isObjectScopeLocked()) ? '*' : ' ') // object_scope == SCOPE_RESERVED\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "*/"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
