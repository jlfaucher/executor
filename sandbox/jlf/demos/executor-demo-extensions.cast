[0.000, "o", "\u001b[1;34m----------------------\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- Executor extensions\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m----------------------\r\n\u001b[0m"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe directive ::EXTENSION delegates to the methods .class~define and .class~inherit.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe changes are allowed on predefined classes, and are propagated to existing instances.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m>>-::EXTENSION--classname----+-------------------+-----------------><\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m                             +-INHERIT--iclasses-+\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mExamples of extensions:\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m::extension Array       inherit ArrayInitializer ArrayPrettyPrinter\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m::extension Object\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m::method isNil\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m    return self == .nil\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
[10.007, "o", "\r\n"]
