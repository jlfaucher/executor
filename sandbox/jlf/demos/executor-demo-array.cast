[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;32mREXX-ooRexx_4.3.0(MT)_64-bit 6.04 12 May 2026\r\n"]
[0.000, "o", "\u001b[0m\u001b[1;32m"]
[0.000, "o", "Input queue name: S1698aQ6000019804e0\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m--------------------\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- Array programming\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m--------------------\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mrank\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mAPL R←⍴⍴Y\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mAn array may have 0 or more axes or dimensions.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe number of axes of an array is known as its rank.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mAn array with 0 axes (rank 0) is called a scalar\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mAn array with 1 axis (rank 1) is called a vector.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mAn array with 2 axes (rank 2) is called a matrix or table.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mAn array with 3 axes (rank 3) is called a cube.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mAn array with more than 2 axes is called a multi-dimensional array\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
[12.940, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mshape\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mAPL R←⍴Y (Rho)\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe shape of a scalar is an empty vector []\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe shape of an array is an array which gives the size of each dimension.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[4.706, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mooRexx:\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mAny object other than an array is a scalar.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mIn particular, a string is a scalar, not an array as in APL.\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mSpecial case which does not exist in APL : The rank of an array with no dimension yet assigned is -1.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[7.107, "o", "\r\n"]
[0.002, "o", "\u001b[1;34m-- scalar"]
