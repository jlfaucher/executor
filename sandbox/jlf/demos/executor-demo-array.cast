[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mAPL R←≡Y (Equal Underbar)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mDepth (≡) indicates the degree of nesting within an array.\r\n"]
[0.000, "o", "\u001b[0m"]
