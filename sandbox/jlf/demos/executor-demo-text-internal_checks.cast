[0.000, "o", "\u001b[0m"]
[0.002, "o", "\u001b[1;34mA \"noncharacter\" is a code point that is permanently reserved in the Unicode Standard for internal use.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThey are considered unassigned to any abstract character, and they share the General_Category value Cn (Unassigned) with unassigned reserved code points in the standard.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mUnicode has exactly 66 noncharacters.\r\n"]
[0.000, "o", "\u001b[0m"]
