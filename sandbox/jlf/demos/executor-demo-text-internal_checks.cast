[0.000, "o", "\u001b[1;32mInput queue name: Sb1fcQ6000019d5930\r\n\u001b[0m"]
[0.001, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m-- These demos were designed before the introduction of the immediate\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- \"invalid text\" error and before the introduction of the privileged encoding\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- status of Byte_Encoding.\r\n\u001b[0m"]
