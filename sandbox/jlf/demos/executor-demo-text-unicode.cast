[0.000, "o", "/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mEscape characters can be used in string literals, they are unescaped at run-time.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mNote: should be supported at parse-time, it's just that this prototype doesn't\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "modify the lexer, for the moment.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    \\N{Unicode name}    Character name in the Unicode database or codepoint Label\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m    \\u{Unicode name}    Character name in the Unicode database or codepoint Label\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    \\U{Unicode name}    same as \\u{Unicode name}\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    \\u{X..X}            Unicode character denoted by 1-8 hex digits. The first character must be a digit 0..9"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "    \\U{X..X}            same as \\u{X..X}\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "    \\uXXXX              Unicode character denoted by 4 hex digits ('u' lowercase)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    \\UXXXXXXXX          Unicode character denoted by 8 hex digits ('U' uppercase)\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "    \\xXX                1 byte denoted by 2 hex digits ('x' lowercase)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "    \\XXXXX              2 bytes denoted by 4 hex digits ('X' uppercase)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m"]
[0.000, "o", "*/\r\n"]
