[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe normalized text can be memorized on the original text:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    text = \"père Noël\"~text\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "    textNFD = text~nfd(memorize:)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mFrom now, the returned NFD is always the memorized text.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
