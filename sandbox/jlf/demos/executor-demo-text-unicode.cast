[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mutf8proc doesn't support language-sensitive case-folding.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mThe Julia developers, who use utf8proc, have decided to remain locale-independent.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mSee https://github.com/JuliaLang/julia/issues/7848\r\n"]
