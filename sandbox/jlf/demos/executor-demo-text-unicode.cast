[0.001, "o", "\u001b[1;34m-- Lumps certain characters together. See lump.md for details:\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- https://github.com/JuliaStrings/utf8proc/blob/master/lump.md\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- E.g. HYPHEN U+2010 and MINUS U+2212 to ASCII \"-\"\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m-- jlf: I was expecting to have only one space and one \"-\" but that's not the case\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- Seems working as designed...\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- All the concerned characters become the same character, but still remain distinct characters.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "ooRexx[bash]> "]
