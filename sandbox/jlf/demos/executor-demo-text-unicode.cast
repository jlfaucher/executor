[0.052, "o", "\u001b[1;34m--  'le  pere ---noel '\u001b[0m\u001b[0m"]
[2.004, "o", "\r\n"]
[0.014, "o", "'le  pere ---noel '\r\n"]
[2.009, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", "/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mSome comments about the transformations:\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 1  : ( \"l\"   U+006C Ll 1 \"LATIN SMALL LETTER L\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 2  : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 3  : ( \" \"   U+0020 Zs 1 \"SPACE\", \"SP\" )               <-- LUMP (was IDEOGRAPHIC SPACE)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 4  : ( \" \"   U+0020 Zs 1 \"SPACE\", \"SP\" )               <-- LUMP (was OGHAM SPACE MARK)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 5  : ( \"p\"   U+0070 Ll 1 \"LATIN SMALL LETTER P\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 6  : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 7  : ( \"r\"   U+0072 Ll 1 \"LATIN SMALL LETTER R\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 8  : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 9  : ( \" \"   U+0020 Zs 1 \"SPACE\", \"SP\" )               <-- STRIPCC (was TAB)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 10 : ( \"-\"   U+002D Pd 1 \"HYPHEN-MINUS\" )              <-- LUMP (was HYPHEN)\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 11 : ( \"-\"   U+002D Pd 1 \"HYPHEN-MINUS\" )              <-- LUMP (was EN DASH)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 12 : ( \"-\"   U+002D Pd 1 \"HYPHEN-MINUS\" )              <-- LUMP (was EM DASH)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 13 : ( \"n\"   U+006E Ll 1 \"LATIN SMALL LETTER N\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 14 : ( \"o\"   U+006F Ll 1 \"LATIN SMALL LETTER O\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 15 : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 16 : ( \"l\"   U+006C Ll 1 \"LATIN SMALL LETTER L\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 17 : ( \" \"   U+0020 Zs 1 \"SPACE\", \"SP\" )               <-- STRIPCC (was CR+LF)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m*/\r\n"]
[0.000, "o", "\u001b[0m"]
[10.004, "o", "\r\n"]
[0.001, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m-------------------------\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m-- Unicode normalizations\r\n\u001b[0m"]
[0.002, "o", "\u001b[1;34m-------------------------\r\n\u001b[0m"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mNormalization NFC, NFD, NFKC, NFKD.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mhttp://unicode.org/faq/normalization.html\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mImplemented with utf8proc.\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mMethods on RexxText:\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m    ~NFC    ~isNFC\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m    ~NFD    ~isNFD\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m    ~NFKC   ~isNFKC\r\n\u001b[0m"]
[0.002, "o", "\u001b[1;34m    ~NFKD   ~isNFKD\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mPossible values for isNFxx:\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m    -1  unknown\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m     0  no\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m     1  yes\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mA same text can be in several normalization forms.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34mText exclusively containing ASCII characters (U+0000..U+007F) is left unaffected\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mby all of the Normalization Forms: The 4 indicators isNFxx are 1.\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34mThe methods NFxx sets the corresponding indicator isNFxx\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m- on the source text : 0 or 1 (test if both strings are equal)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m- on the result text : 1\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
