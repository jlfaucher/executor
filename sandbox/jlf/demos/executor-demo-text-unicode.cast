[0.003, "o", "T'ẞ'\r\n"]
[2.005, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mUnicode standard 15 section 5.18 Case Mappings:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m    Default casing                                         Tailored casing\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m    (small sharp) ß <--- ẞ (capital sharp)                 (small sharp) ß <--> ẞ (capital sharp)\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m    (small sharp) ß ---> SS\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m                 ss <--> SS                                             ss <--> SS\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mWhen using the default Unicode casing operations, capital sharp s will lowercase\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mto small sharp s, but not vice versa: small sharp s uppercases to “SS”.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34mA tailored casing operation is needed in circumstances requiring small sharp s\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mto uppercase to capital sharp s.\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m*/\r\n\u001b[0m"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[1;34m/*\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mAnother example of wrong result for upper/lower\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m*/"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[0m"]
