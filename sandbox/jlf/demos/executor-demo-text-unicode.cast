[2.016, "o", "\r\nan Array (shape [22], 22 items)\r\n 1  : ( \"\"    U+0007 Cc 0 \"\", \"ALERT\", \"BEL\" )\r\n 2  : ( \"L\"   U+004C Lu 1 \"LATIN CAPITAL LETTER L\" )\r\n 3  : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n 4  : ( \"　\"  U+3000 Zs 2 \"IDEOGRAPHIC SPACE\" )\r\n 5  : ( \" \"   U+1680 Zs 1 \"OGHAM SPACE MARK\" )\r\n 6  : ( \"​\"    U+200B Cf 0 \"ZERO WIDTH SPACE\", \"ZWSP\" )\r\n 7  : ( \"P\"   U+0050 Lu 1 \"LATIN CAPITAL LETTER P\" )\r\n 8  : ( \"è\"   U+00E8 Ll 1 \"LATIN SMALL LETTER E WITH GRAVE\" )\r\n 9  : ( \"r\"   U+0072 Ll 1 \"LATIN SMALL LETTER R\" )\r\n 10 : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.000, "o", " 11 : ( \"\"    U+0009 Cc 0 \"\", \"CHARACTER TABULATION\", \"HORIZONTAL TABULATION\", \"HT\", \"TAB\" )\r\n"]
[0.000, "o", " 12 : ( \"‐\"   U+2010 Pd 1 \"HYPHEN\" )\r\n"]
[0.000, "o", " 13 : ( \"­\"   U+00AD Cf 1 \"SOFT HYPHEN\", \"SHY\" )\r\n"]
[0.000, "o", " 14 : ( \"–\"   U+2013 Pd 1 \"EN DASH\" )\r\n"]
[0.000, "o", " 15 : ( \"—\"   U+2014 Pd 1 \"EM DASH\" )\r\n"]
[0.000, "o", " 16 : ( \"N\"   U+004E Lu 1 \"LATIN CAPITAL LETTER N\" )\r\n"]
[0.000, "o", " 17 : ( \"o\"   U+006F Ll 1 \"LATIN SMALL LETTER O\" )\r\n"]
[0.000, "o", " 18 : ( \"ë\"   U+00EB Ll 1 \"LATIN SMALL LETTER E WITH DIAERESIS\" )\r\n"]
[0.001, "o", " 19 : ( \"l\"   U+006C Ll 1 \"LATIN SMALL LETTER L\" )\r\n"]
[0.000, "o", " 20 : ( \"﷐\"   U+FDD0 Cn 1 \"\" )\r\n"]
[0.000, "o", " 21 : ( \"\"    U+000D Cc 0 \"\", \"CARRIAGE RETURN\", \"CR\" )\r\n"]
[0.000, "o", " 22 : ( \"\"    U+000A Cc 0 \"\", \"LINE FEED\", \"NEW LINE\", \"END OF LINE\", \"LF\", \"NL\", \"EOL\" )\r\n"]
[2.005, "o", "\r\n"]
[0.000, "o", "\u001b[1;34m/*\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34mPossible transformations:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 1  : ( \"\"    U+0007 Cc 0 \"\", \"ALERT\", \"BEL\" )                      <-- removable with STRIPCC:\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m 2  : ( \"L\"   U+004C Lu 1 \"LATIN CAPITAL LETTER L\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 3  : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 4  : ( \"　\"  U+3000 Zs 2 \"IDEOGRAPHIC SPACE\" )                     <-- replaceable by \" \" with LUMP:"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 5  : ( \" \"   U+1680 Zs 1 \"OGHAM SPACE MARK\" )                      <-- replaceable by \" \" with LUMP:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 6  : ( \"​\"    U+200B Cf 0 \"ZERO WIDTH SPACE\", \"ZWSP\" )              <-- removable by STRIPIGNORABLE:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 7  : ( \"P\"   U+0050 Lu 1 \"LATIN CAPITAL LETTER P\" )\r\n\u001b[0m"]
[0.000, "o", "\u001b[1;34m 8  : ( \"è\"   U+00E8 Ll 1 \"LATIN SMALL LETTER E WITH GRAVE\" )       <-- replaceable by \"e\" with normalization + STRIPMARK:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 9  : ( \"r\"   U+0072 Ll 1 \"LATIN SMALL LETTER R\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 10 : ( \"e\"   U+0065 Ll 1 \"LATIN SMALL LETTER E\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 11 : ( \"\"    U+0009 Cc 0 \"\", \"CHARACTER TABULATION\" )              <-- replaceable by \" \" with STRIPCC:"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 12 : ( \"‐\"   U+2010 Pd 1 \"HYPHEN\" )                                <-- replaceable by \"-\" with LUMP:"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 13 : ( \"­\"   U+00AD Cf 1 \"SOFT HYPHEN\", \"SHY\" )                    <-- removable by STRIPIGNORABLE:"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 14 : ( \"–\"   U+2013 Pd 1 \"EN DASH\" )                               <-- replaceable by \"-\" with LUMP:\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m 15 : ( \"—\"   U+2014 Pd 1 \"EM DASH\" )                               <-- replaceable by \"-\" with LUMP:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 16 : ( \"N\"   U+004E Lu 1 \"LATIN CAPITAL LETTER N\" )\r\n"]
[0.000, "o", "\u001b[0m"]
