[0.000, "o", "\u001b[0m"]
[0.001, "o", "\u001b[1;34m 18 : ( \"ë\"   U+00EB Ll 1 \"LATIN SMALL LETTER E WITH DIAERESIS\" )   <-- replaceable by \"e\" with normalization + STRIPMARK:\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m 19 : ( \"l\"   U+006C Ll 1 \"LATIN SMALL LETTER L\" )\r\n"]
[0.000, "o", "\u001b[0m"]
[0.000, "o", "\u001b[1;34m"]
[0.000, "o", " 20 : ( \"﷐\"   U+FDD0 Cn 1 \"\" )                                     <-- removeable with STRIPNA:\r\n\u001b[0m"]
[0.001, "o", "\u001b[1;34m 21 : ( \"\"    U+000D Cc 0 \"\", \"CARRIAGE RETURN\", \"CR\" )\r\n"]
[0.000, "o", "\u001b[0m"]
