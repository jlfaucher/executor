prompt off address directory
demo on


-- =============================================================================
-- Default width
-- =============================================================================

-- -----------------------------------------------------------------------------
-- Normal
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?c filter

-- -----------------------------------------------------------------------------
?cm filter

-- -----------------------------------------------------------------------------
?cmi filter <> `MPF(REXX)`


-- -----------------------------------------------------------------------------
-- Verbose
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?cv filter

-- -----------------------------------------------------------------------------
?cmv filter

-- -----------------------------------------------------------------------------
?cmiv filter <> `MPF(REXX)`


-- -----------------------------------------------------------------------------
-- With source
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?cms filter

-- -----------------------------------------------------------------------------
?cmis filter <> `MPF(REXX)`


-- -----------------------------------------------------------------------------
-- With source, verbose
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?cmsv filter

-- -----------------------------------------------------------------------------
?cmisv filter <> `MPF(REXX)`


