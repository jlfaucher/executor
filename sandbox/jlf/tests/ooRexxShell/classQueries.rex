prompt off address directory
demo on


-- =============================================================================
-- Default width
-- =============================================================================

-- -----------------------------------------------------------------------------
-- Normal
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?classes filter

-- -----------------------------------------------------------------------------
?classes.methods filter

-- -----------------------------------------------------------------------------
?classes.methods.inherited filter <> `MPF(REXX)`


-- -----------------------------------------------------------------------------
-- Verbose
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?classes.verbose filter

-- -----------------------------------------------------------------------------
?classes.methods.verbose filter

-- -----------------------------------------------------------------------------
?classes.methods.inherited.verbose filter <> `MPF(REXX)`


-- -----------------------------------------------------------------------------
-- With source
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?classes.methods.source filter

-- -----------------------------------------------------------------------------
?classes.methods.inherited.source filter <> `MPF(REXX)`


-- -----------------------------------------------------------------------------
-- With source, verbose
-- -----------------------------------------------------------------------------

-- -----------------------------------------------------------------------------
?classes.methods.source.verbose filter

-- -----------------------------------------------------------------------------
?classes.methods.inherited.source.verbose filter <> `MPF(REXX)`


